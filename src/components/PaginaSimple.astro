---
import { getEntry, render } from 'astro:content';
import Layout from './Layout.astro';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  slug: string;
  current: 'home' | 'negra40' | 'proyectos' | 'textos' | 'links' | 'contacto';
  path: string;
}

const { lang, slug, current, path } = Astro.props;
const page = await getEntry('paginas', `${lang}/${slug}`);
const { Content } = await render(page!);
---

<Layout lang={lang} title={page!.data.title} current={current} path={path}>
  <div class="prose" style="margin-top: 3rem;">
    <h1>{page!.data.title}</h1>
    <Content />
  </div>
</Layout>
