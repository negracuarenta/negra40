---
import { getEntry } from 'astro:content';
import Layout from '../../components/Layout.astro';
import { t } from '../../i18n/ui';

const page = await getEntry('links', 'es');
const items = page!.data.items;
---

<Layout lang="es" title={t('es', 'nav_links')} current="links" path="/links/">
  <div class="prose" style="margin-top: 3rem;">
    <h1>{t('es', 'nav_links')}</h1>
  </div>
  <ul class="list-simple">
    {
      items.map((item) => (
        <li>
          <a class="item-title" href={item.url} target="_blank" rel="noopener noreferrer">
            {item.title} ↗
          </a>
        </li>
      ))
    }
  </ul>
</Layout>
